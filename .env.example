# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dugate

# NextAuth (for optional login feature)
NEXTAUTH_SECRET=run-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:2023

# Encryption key for API key storage (exactly 32 chars)
ENCRYPTION_KEY=change-this-to-a-32-char-string!

# AI (optional — can also configure via UI at /settings)
# GEMINI_API_KEY=your-key-here

# OIDC / SSO (optional — enable for external IDP login)
# NEXT_PUBLIC_OIDC_ENABLED=true
# OIDC_ISSUER=https://your-idp.example.com/realms/dugate
# OIDC_CLIENT_ID=dugate
# OIDC_CLIENT_SECRET=your-client-secret

# File paths
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# Server
PORT=2023

# Auto-run Prisma db push + seed on container start (set to false after initial deploy)
MIGRATION=true

# Seed credentials (used by prisma/seed.ts — override for security in production)
SEED_ADMIN_KEY=change-this-seed-admin-key-before-use
SEED_ADMIN_PASSWORD=change-this-seed-admin-password-before-use
